# ============================================================================
# feishu-plugin-platform  —  Go backend + Node/TS (basekit plugin + web)
# Hybrid repo. Rules are intentionally broad: this repo carries real Feishu
# app secrets and build-time-injected bearer tokens, so prefer over-ignoring.
# ============================================================================

# ── Secrets / credentials — NEVER commit ────────────────────────────────────
# .env.local holds FEISHU_APP_SECRET + api_key for local STORE=bitable runs.
.env
.env.*
*.local
# ...but keep the committed templates/examples.
!.env.example
!.env.*.example
!*.example

# Feishu webview / browser-automation login state == credential-equivalent
# (publisher/ logs into the Developer Console with these).
state.json
*.state.json

# Any private key / signing key / cert
*.pem
*.key
*.p12
*.pfx

# ── Node / TypeScript (root, frontend/, web/, plugin/block/, publisher/) ─────
# Match at any depth so every workspace's deps are covered.
node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo

# ── Build output — every nested dist/ + Vite/Webpack/Go build dirs ──────────
# CRITICAL: plugin/block/dist/ embeds PLATFORM_API_TOKEN at build time via
# webpack DefinePlugin (baked into main.js/vendor.js) — never commit it.
dist/
**/dist/
build/
**/build/
out/
output/
**/output/
.vite/
.cache/
.parcel-cache/

# ── Go ───────────────────────────────────────────────────────────────────
# Compiled binaries from `make build` -> ./bin/{api,generator,bitable-bootstrap}
# plus shortcutgen and any stray `go build` output left in cmd/*/.
/bin/
bin/
/api
/generator
/shortcutgen
/bitable-bootstrap
cmd/*/api
cmd/*/generator
cmd/*/shortcutgen
cmd/*/bitable-bootstrap
# Go test / profiling / coverage artifacts
*.out
*.test
*.exe
*.exe~
*.dll
*.so
*.dylib
coverage.txt
coverage.html
*.cover
*.coverprofile
profile.cov
go.work
go.work.sum
vendor/

# ── Test / coverage (JS side) ───────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/

# ── Logs / runtime ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.seed

# ── OS noise ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE / editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── RPA screenshots (expose account avatar / owner identity / app list) ─────
publisher/screenshots/
# ── Generated scaffold project downloads ───────────────────────────────────
*.zip

# ── Local agent / tooling data ──────────────────────────────────────────────
.claude/
