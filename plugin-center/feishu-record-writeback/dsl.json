{
  "id": "write-back-record",
  "title": {"zh_CN": "写回多维表格记录"},
  "domains": ["open.feishu.cn"],
  "inputs": [
    {"key": "appId", "label": "应用 App ID", "required": true},
    {"key": "appSecret", "label": "应用 App Secret", "required": true},
    {"key": "appToken", "label": "目标多维表格 app_token", "required": true},
    {"key": "tableId", "label": "目标数据表 table_id", "required": true},
    {"key": "title", "label": "标题内容", "required": true},
    {"key": "content", "label": "正文内容", "required": true}
  ],
  "result": [
    {"key": "code", "label": "返回码(0为成功)", "type": "Number", "expr": "res.code"},
    {"key": "record_id", "label": "新记录ID", "type": "Text", "expr": "res.data.records.0.record_id"}
  ],
  "steps": [
    {"id": "token", "url": "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal", "method": "POST", "bodyJson": {"app_id": "{appId}", "app_secret": "{appSecret}"}},
    {"id": "create", "url": "https://open.feishu.cn/open-apis/bitable/v1/apps/{appToken}/tables/{tableId}/records/batch_create", "method": "POST", "headers": {"Authorization": "Bearer {token.tenant_access_token}"}, "bodyJson": {"records": [{"fields": {"标题": "{title}", "正文": "{content}"}}]}}
  ]
}
