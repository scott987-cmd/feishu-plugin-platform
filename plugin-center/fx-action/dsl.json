{
  "id": "cny-to-usd-converter",
  "title": {
    "zh_CN": "人民币兑美元换算"
  },
  "domains": [
    "api.exchangerate-api.com"
  ],
  "inputs": [
    {
      "key": "amount",
      "label": "人民币金额",
      "required": true
    }
  ],
  "result": [
    {
      "key": "usd_amount",
      "label": "美元金额",
      "type": "Number",
      "expr": "in.amount * res.rates.USD"
    },
    {
      "key": "exchange_rate",
      "label": "汇率",
      "type": "Number",
      "expr": "res.rates.USD"
    }
  ],
  "execute": {
    "url": "https://api.exchangerate-api.com/v4/latest/CNY",
    "method": "GET"
  }
}
