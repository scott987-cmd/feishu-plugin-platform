# Multi-stage build for the generator service. Stdlib-only, so no module download.
FROM golang:1.24 AS build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/generator ./cmd/generator

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/generator /generator
ENV PORT=8090
EXPOSE 8090
USER nonroot:nonroot
ENTRYPOINT ["/generator"]
