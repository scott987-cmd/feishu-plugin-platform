[
  {
    "nl": "自动化：输入人民币金额，按实时汇率换算成美元，输出美元金额和汇率供后续步骤使用",
    "dsl": {
      "id": "cny-to-usd-action",
      "title": { "zh_CN": "汇率换算动作" },
      "domains": ["api.exchangerate-api.com"],
      "inputs": [{ "key": "amount", "label": "人民币金额", "required": true }],
      "result": [
        { "key": "usd_amount", "label": "美元金额", "type": "Number", "expr": "in.amount * res.rates.USD" },
        { "key": "exchange_rate", "label": "汇率", "type": "Number", "expr": "res.rates.USD" }
      ],
      "execute": { "url": "https://api.exchangerate-api.com/v4/latest/CNY", "method": "GET" }
    }
  },
  {
    "nl": "自动化:把工单状态更新写回外部工单系统(PATCH,结构化请求体)",
    "dsl": {
      "id": "update-ticket-action",
      "title": { "zh_CN": "更新工单动作" },
      "domains": ["api.example.com"],
      "inputs": [
        { "key": "ticketId", "label": "工单ID", "required": true },
        { "key": "status", "label": "新状态", "required": true }
      ],
      "result": [
        { "key": "ok", "label": "更新结果", "type": "Text", "expr": "res.status" }
      ],
      "execute": { "url": "https://api.example.com/v1/tickets/{ticketId}", "method": "PATCH", "bodyJson": { "status": "{status}" } }
    }
  },
  {
    "nl": "把数据写回飞书多维表格的一条新记录(连接器:先取 tenant_access_token,再 batch_create)",
    "dsl": {
      "id": "feishu-record-writeback",
      "title": { "zh_CN": "写回多维表格记录" },
      "domains": ["open.feishu.cn"],
      "inputs": [
        { "key": "appId", "label": "应用 App ID", "required": true },
        { "key": "appSecret", "label": "应用 App Secret", "required": true },
        { "key": "appToken", "label": "多维表格 app_token", "required": true },
        { "key": "tableId", "label": "数据表 table_id", "required": true },
        { "key": "title", "label": "标题内容", "required": true }
      ],
      "result": [
        { "key": "code", "label": "返回码(0成功)", "type": "Number", "expr": "res.code" },
        { "key": "record_id", "label": "新记录ID", "type": "Text", "expr": "res.data.records.0.record_id" }
      ],
      "steps": [
        { "id": "token", "url": "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal", "method": "POST", "bodyJson": { "app_id": "{appId}", "app_secret": "{appSecret}" } },
        { "id": "create", "url": "https://open.feishu.cn/open-apis/bitable/v1/apps/{appToken}/tables/{tableId}/records/batch_create", "method": "POST", "headers": { "Authorization": "Bearer {token.tenant_access_token}" }, "bodyJson": { "records": [{ "fields": { "标题": "{title}" } }] } }
      ]
    }
  }
]
