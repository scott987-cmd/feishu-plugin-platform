# 部署/发版配置模板。复制为 scripts/deploy.env 并填值:
#   cp scripts/deploy.example.env scripts/deploy.env
# deploy.env 含主机/密钥路径,已被 .gitignore 忽略,切勿提交。
# 所有脚本(deploy-backend.sh / release-widget.sh / release.sh)都从这里读配置。

# ── 后端服务器(运行 docker compose 的那台)────────────────────
# 标准飞书 SaaS 与私有化飞书都适用:只要这台服务器能被飞书 webview 通过 HTTPS 访问。
SERVER_HOST="ec2-user@203.0.113.5"          # ssh 目标
SSH_KEY="$HOME/.ssh/your-key.pem"           # ssh 私钥(放在 ~/.ssh,避开 macOS ~/Downloads 的 TCC 限制)
REMOTE_DIR="~/fpp"                          # 服务器上仓库目录(首次部署会自动创建)
COMPOSE_FILE="docker-compose.prod.yml"      # deploy/compose/ 下的 compose 文件

# ── 对外地址 / 鉴权(用于把插件构建期指向后端)──────────────────
# 飞书 webview 要求合法 TLS 域名;免买域名可用 sslip.io(<IP>.sslip.io)。
PLATFORM_API_BASE="https://203.0.113.5.sslip.io"
# 平台 Bearer。留空则脚本自动从服务器 deploy/compose/.env 读取 PLATFORM_API_TOKEN
# (推荐留空,避免 token 落到本地文件)。
PLATFORM_API_TOKEN=""

# ── 飞书插件发版(opdev)────────────────────────────────────────
OPDEV_BIN="opdev"                           # opdev 可执行路径(如 /tmp/opdev-cli/node_modules/.bin/opdev)
PLUGIN_DIR="plugin"                         # opdev upload 的工作目录(含 app.json)
WIDGET_DIST="./block/dist"                  # 相对 PLUGIN_DIR 的构建产物目录
# 真实 appId / blockTypeID(仓库内 app.json/block.json 存的是占位符,发版前注入)。
FEISHU_APP_ID="cli_xxxxxxxxxxxxxxxx"
WIDGET_BLOCK_TYPE_ID="blk_xxxxxxxxxxxxxxxx"
